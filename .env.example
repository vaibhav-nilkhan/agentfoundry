# ==============================================
# AgentFoundry - Environment Configuration
# ==============================================
# Copy this file to .env and update with your values
# Quick Start: Most defaults work for local development
# ==============================================

# ----------------------------------------------
# Application URLs
# ----------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3100
NEXT_PUBLIC_API_URL=http://localhost:4100

# ----------------------------------------------
# Service Ports (customizable to avoid conflicts)
# ----------------------------------------------
WEB_PORT=3100
API_PORT=4100
VALIDATOR_PORT=5100
POSTGRES_PORT=5432
REDIS_PORT=6379

# ----------------------------------------------
# Database Configuration (PostgreSQL)
# ----------------------------------------------
POSTGRES_USER=agentfoundry
POSTGRES_PASSWORD=agentfoundry_dev_password
POSTGRES_DB=agentfoundry

# Full DATABASE_URL (auto-constructed from above in Docker)
DATABASE_URL=postgresql://agentfoundry:agentfoundry_dev_password@localhost:5432/agentfoundry?schema=public

# ----------------------------------------------
# Redis Configuration
# ----------------------------------------------
REDIS_URL=redis://localhost:6379

# ----------------------------------------------
# Supabase Configuration
# Get your credentials from: https://supabase.com/dashboard
# ----------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# For Next.js (public variables)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ----------------------------------------------
# Security Keys (CHANGE THESE IN PRODUCTION!)
# ----------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-me-in-production
API_KEY=your-api-key-for-admin-endpoints-change-me

# ----------------------------------------------
# Optional: External Services
# ----------------------------------------------

# Stripe (for payments - optional for now)
# STRIPE_PUBLIC_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# SendGrid (for emails - optional for now)
# SENDGRID_API_KEY=SG...
# SENDGRID_FROM_EMAIL=noreply@agentfoundry.com

# Sentry (for error tracking - optional for now)
# SENTRY_DSN=https://...@sentry.io/...
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# ----------------------------------------------
# Environment Mode
# ----------------------------------------------
NODE_ENV=development
# For production, set to: production

# ==============================================
# SETUP INSTRUCTIONS
# ==============================================
#
# 1. Copy this file:
#    cp .env.example .env
#
# 2. For LOCAL DEVELOPMENT:
#    - Keep all defaults as-is
#    - Only update SUPABASE_* variables
#    - Get Supabase credentials from: https://supabase.com
#
# 3. For DOCKER DEPLOYMENT:
#    - Defaults work out of the box!
#    - Run: docker-compose up
#
# 4. For PRODUCTION:
#    - Change all *_PASSWORD and *_SECRET values
#    - Use strong, random passwords
#    - Set NODE_ENV=production
#    - Configure Stripe, SendGrid if needed
#
# ==============================================
