# ==============================================
# Root .dockerignore - AgentFoundry
# ==============================================
# Excludes files from Docker build context to speed up builds

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Development
.next/
.turbo/
dist/
build/
out/
*.log

# Environment
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# IDEs and Editors
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Git
.git/
.gitignore
.gitattributes

# Documentation (not needed in container)
*.md
!README.md
docs/
examples/

# Testing
coverage/
.nyc_output/
*.test.ts
*.spec.ts
__tests__/
**/__tests__/
**/*.test.ts
**/*.spec.ts

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
ENV/
.pytest_cache/
*.egg-info/

# Database
*.sqlite
*.db
prisma/migrations/
*.sql

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.backup

# Archives
*.zip
*.tar
*.tar.gz
*.rar

# Keep these (override with !)
!packages/*/prisma/schema.prisma
!packages/db/prisma/
