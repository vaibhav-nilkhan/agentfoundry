{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgentFoundry Skill Manifest",
  "description": "JSON schema for skill.json files",
  "type": "object",
  "required": [
    "name",
    "version",
    "description",
    "author",
    "platforms",
    "permissions"
  ],
  "properties": {
    "name": {
      "type": "string",
      "description": "Skill name (lowercase-with-dashes)",
      "pattern": "^[a-z0-9-]+$"
    },
    "version": {
      "type": "string",
      "description": "Semantic version (e.g., 1.0.0)",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.]+)?(\\+[a-zA-Z0-9.]+)?$"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 200
    },
    "author": {
      "type": "string"
    },
    "platforms": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["MCP", "CLAUDE_SKILLS", "GPT_ACTIONS", "LANGCHAIN", "MISTRAL"]
      },
      "minItems": 1
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description", "inputSchema"],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "inputSchema": {
            "type": "object"
          }
        }
      }
    }
  }
}
