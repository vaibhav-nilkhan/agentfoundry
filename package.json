{
  "name": "agentfoundry",
  "version": "0.1.0",
  "private": true,
  "description": "AgentFoundry tracks, analyzes, and optimizes how you use AI coding agents.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:migrate": "pnpm --filter @agentfoundry/db migrate",
    "db:studio": "pnpm --filter @agentfoundry/db studio",
    "validator:dev": "cd packages/validator && poetry run uvicorn app.main:app --reload"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "turbo": "^1.11.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.14.0"
}