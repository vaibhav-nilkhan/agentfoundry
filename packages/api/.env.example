# Server Configuration
# Change PORT to avoid conflicts with other projects (e.g., 4100, 4200, etc.)
PORT=4100
NODE_ENV=development
CORS_ORIGIN=http://localhost:3100

# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Database (Self-hosted PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/agentfoundry?schema=public"

# Redis (change port if Redis is already running on 6379)
REDIS_URL=redis://localhost:6379

# Validator Service (change to avoid conflicts, e.g., 5100, 5200, etc.)
VALIDATOR_URL=http://localhost:5100
