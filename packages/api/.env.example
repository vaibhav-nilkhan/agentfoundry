# Server Configuration
PORT=4100
NODE_ENV=development

# Database (from @agentfoundry/db)
DATABASE_URL="postgresql://postgres@127.0.0.1:5432/agentfoundry?schema=public"

# Supabase (for authentication)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redis (optional - for caching)
REDIS_HOST=localhost
REDIS_PORT=6379

# Stripe Integration (for payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_CREATOR=price_your_creator_price_id
STRIPE_PRICE_PRO=price_your_pro_price_id
STRIPE_PRICE_ENTERPRISE=price_your_enterprise_price_id

# Validator Service
VALIDATOR_URL=http://localhost:5100
