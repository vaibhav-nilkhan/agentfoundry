{
  "name": "@agentfoundry/cli",
  "version": "0.1.0",
  "description": "Command-line tool for AgentFoundry Skill development",
  "main": "dist/index.js",
  "bin": {
    "agentfoundry": "./dist/cli.js",
    "af": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "agentfoundry",
    "cli",
    "ai",
    "skills"
  ],
  "dependencies": {
    "commander": "^11.1.0",
    "inquirer": "^9.2.12",
    "chalk": "^4.1.2",
    "ora": "^5.4.1",
    "axios": "^1.6.5",
    "dotenv": "^16.3.1",
    "fs-extra": "^11.2.0",
    "@agentfoundry/sdk": "workspace:*",
    "@agentfoundry/shared": "workspace:*",
    "@agentfoundry/mcp-adapter": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@types/inquirer": "^9.0.7",
    "@types/fs-extra": "^11.0.4",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "eslint": "^8.56.0"
  }
}
