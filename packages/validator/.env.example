# Server Configuration
HOST=0.0.0.0
# Change PORT to avoid conflicts with other projects (e.g., 5100, 5200, etc.)
PORT=5100

# CORS (update to match your frontend and API ports)
CORS_ORIGINS=["http://localhost:3100", "http://localhost:4100"]

# Redis (change port if Redis is already running on 6379)
REDIS_URL=redis://localhost:6379

# Validation Settings
MAX_FILE_SIZE_MB=10
VALIDATION_TIMEOUT_SECONDS=60
SANDBOX_ENABLED=true
