// AgentFoundry V2 Tracker Schema
// Multi-tenant support for Team Mode (SQLite compatible)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String?
  image         String?
  
  memberships   Membership[]
  sessions      AgentSession[]
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Team {
  id            String       @id @default(cuid())
  name          String
  slug          String       @unique
  
  memberships   Membership[]
  sessions      AgentSession[]
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Membership {
  id        String   @id @default(cuid())
  role      String   @default("MEMBER") // SQLite doesn't support Enums, using String
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, teamId])
}

model AgentSession {
  id              String           @id @default(cuid())
  agentName       String           // e.g., 'claude-code', 'codex', 'gemini'
  taskHint        String?          // e.g., command line args
  taskType        String?          // Auto-classified from files changed
  swarmId         String?          // Optional ID to group concurrent agent sessions
  benchmarkId     String?          // Optional ID to group agents competing on the same task

  startedAt       DateTime         @default(now())
  endedAt         DateTime?
  durationSeconds Int?
  
  // Relations for Multi-tenancy
  userId          String?
  user            User?            @relation(fields: [userId], references: [id])
  
  teamId          String?
  team            Team?            @relation(fields: [teamId], references: [id])
  
  cost            CostRecord?
  quality         QualityMetrics?
  gitSnapshot     GitSnapshot?
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model CostRecord {
  id              String       @id @default(cuid())
  sessionId       String       @unique
  session         AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  tokensIn        Int          @default(0)
  tokensOut       Int          @default(0)
  costUsd         Float        @default(0.0)
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model QualityMetrics {
  id              String       @id @default(cuid())
  sessionId       String       @unique
  session         AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  testsPassed     Int          @default(0)
  testsFailed     Int          @default(0)
  lintIssues      Int          @default(0)
  buildSuccess    Boolean      @default(true)
  
  // Advanced Efficiency Metrics (Karpathy Insight)
  tokenYield      Float?       // (Tokens Out / Net Lines Changed) - Lower is better (less thrashing)
  isZeroShot      Boolean?     // True if passed tests without prior failed sessions in close proximity
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model GitSnapshot {
  id              String       @id @default(cuid())
  sessionId       String       @unique
  session         AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  filesChanged    String       // JSON stringified array of changed files
  linesAdded      Int          @default(0)
  linesRemoved    Int          @default(0)
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}
